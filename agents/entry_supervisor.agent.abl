SUPERVISOR: Entry_Supervisor
VERSION: "2.2"
DESCRIPTION: "Entry router for AFG bot - classifies and routes to domain agents"

GOAL: |
  Classify customer requests and route to the appropriate specialist agent.
  Handle profile information updates directly.

PERSONA: |
  You are the front door of the AFG (Al-Futtaim Group) assistant.
  
  CLASSIFICATION RULES:
  You classify user queries into these categories:
  
  1. Product_Search - Retail products like Accessories, Handbags, Clothing, Footwear, 
     perfumes, Jewellery, Makeup, Skincare, toys, Home items, Bath & Body
     Route to Product_Search_Discovery
  
  2. Automobiles - Cars, vehicles, brands like Toyota, Lexus, BYD, Honda, Jeep, BMW, etc.
     Route to Automobile_Discovery
  
  3. Offers/Promotions - Deals, discounts, sales (without specific product)
     Route to Promotions_Offers
  
  4. Store/Restaurant - Store locations, restaurants, cafes, dining
     Route to Discovery_Services
  
  5. Health - Doctor appointments, clinics, pharmacies, HealthHub
     Route to Discovery_Services
  
  6. Cart/Wishlist - View cart, manage wishlist, add to cart
     Route to Cart_Wishlist_Management
  
  7. Checkout/Orders - Payment, checkout, order tracking
     Route to Unified_Checkout
  
  8. FAQ/Help - Questions about policies, services, Blue app, insurance
     Route to FAQ_Knowledge
  
  GENDER INFERENCE (for product searches):
  - Explicit mention (father/mother/he/she) use that gender
  - for me/myself with no explicit gender is neutral
  - Child references (son/daughter/boy/girl) are boys/girls
  - Baby/infant/toddler is baby
  - Product type defaults: dress/skirt/heels/makeup are women, shaving kit is men
  - No signal is neutral

EXECUTION:
  pipeline:
    enabled: true
    mode: sequential
    shortCircuit:
      enabled: true
      confidenceThreshold: 0.85

ON_START:
  CALL: get_session_context()
  RESPOND: "Hi"

LIMITATIONS:
  - "Cannot process orders or payments - route to Unified_Checkout"
  - "Cannot search products - route to Product_Search_Discovery"
  - "Cannot authenticate users - authentication handled externally"

TOOLS:
  get_session_context() -> {country: string, language: string, currency: string, product_categories: string, sessionId: string}
    description: "Get session context from WebSDK custom variables including country, language, currency, and country-specific product categories"
    on_result:
      set:
        Country: result.country
        currentLanguage: result.language
        currency: result.currency
        product_categories: result.product_categories
        conversationSessionId: result.sessionId

  render_response(response: string, data: object, template_id: string = "") -> {success: boolean, rendered: string}
    description: "Render all user-facing responses"
    on_result:
      do:
        - RESPOND: "{{result.rendered}}"

  set_update_profile() -> {template_id: string, instance_id: string}
    description: "Get the template values for profile update"
    on_result:
      set:
        template_id: result.output.output.template_id
        instance_id: result.output.output.instance_id

GATHER:
  profile_field:
    prompt: "Which profile information would you like to update?"
    type: string
    required: false

  profile_value:
    prompt: "What should the new value be?"
    type: string
    required: false

MEMORY:
  session:
    - conversationSessionId
      TYPE: string
      DESCRIPTION: "Session ID from WebSDK"
    - currentLanguage
      TYPE: string
      DESCRIPTION: "User language preference"
    - Country
      TYPE: string
      DESCRIPTION: "User country code (uae, sau, qat, etc.)"
    - currency
      TYPE: string
      DESCRIPTION: "Currency based on country"
    - product_categories
      TYPE: string
      DESCRIPTION: "Country-specific product categories"
    - user_intent_history
    - last_routed_agent
    - template_id
    - instance_id

HANDOFF:
  - TO: Product_Search_Discovery
    WHEN: input.contains("product") OR input.contains("buy") OR input.contains("shop") OR input.contains("looking for") OR input.contains("find") OR input.contains("dress") OR input.contains("shirt") OR input.contains("shoes") OR input.contains("bag") OR input.contains("perfume") OR input.contains("makeup") OR input.contains("jewelry") OR input.contains("clothing") OR input.contains("fashion") OR input.contains("beauty")
    CONTEXT:
      pass: [conversationSessionId, currentLanguage, Country, currency, product_categories]
      summary: "User wants to search, browse, or view product details"
    EXPECT_RETURN: false

  - TO: Automobile_Discovery
    WHEN: input.contains("car") OR input.contains("vehicle") OR input.contains("toyota") OR input.contains("lexus") OR input.contains("byd") OR input.contains("bmw") OR input.contains("honda") OR input.contains("jeep") OR input.contains("audi") OR input.contains("mercedes")
    CONTEXT:
      pass: [conversationSessionId, currentLanguage, Country, currency]
      summary: "User wants to discover or configure a vehicle"
    EXPECT_RETURN: false

  - TO: Discovery_Services
    WHEN: input.contains("restaurant") OR input.contains("store") OR input.contains("doctor") OR input.contains("clinic") OR input.contains("appointment") OR input.contains("mall") OR input.contains("cafe") OR input.contains("pharmacy")
    CONTEXT:
      pass: [conversationSessionId, currentLanguage, Country]
      summary: "User wants venues, health services, or lifestyle exploration"
    EXPECT_RETURN: false

  - TO: Cart_Wishlist_Management
    WHEN: input.contains("cart") OR input.contains("basket") OR input.contains("wishlist") OR input.contains("add to cart") OR input.contains("my bag")
    CONTEXT:
      pass: [conversationSessionId, currentLanguage, Country]
      summary: "User wants to manage cart or wishlist"
    EXPECT_RETURN: false

  - TO: Unified_Checkout
    WHEN: input.contains("checkout") OR input.contains("pay") OR input.contains("order status") OR input.contains("track") OR input.contains("payment") OR input.contains("order")
    CONTEXT:
      pass: [conversationSessionId, currentLanguage, Country, currency]
      summary: "User wants checkout, payment, or order management"
    EXPECT_RETURN: false

  - TO: Promotions_Offers
    WHEN: input.contains("offer") OR input.contains("discount") OR input.contains("deal") OR input.contains("promotion") OR input.contains("sale")
    CONTEXT:
      pass: [conversationSessionId, currentLanguage, Country]
      summary: "User wants promotions or offers"
    EXPECT_RETURN: false

  - TO: FAQ_Knowledge
    WHEN: input.contains("how do i") OR input.contains("what is") OR input.contains("faq") OR input.contains("policy") OR input.contains("return") OR input.contains("help") OR input.contains("support")
    CONTEXT:
      pass: [conversationSessionId, currentLanguage, Country]
      summary: "User has a question for the knowledge base"
    EXPECT_RETURN: false

  - TO: GENERIC_RENDERING
    WHEN: template_id IS SET AND instance_id IS SET
    CONTEXT:
      pass: [template_id, instance_id]
    RETURN: false

ON_ERROR:
  routing_failure:
    RESPOND: "I'm having trouble understanding. Could you tell me more about what you're looking for?"
    RETRY: 1

  tool_timeout:
    RESPOND: "Just a moment..."
    RETRY: 2

COMPLETE:
  - WHEN: input.contains("goodbye") OR input.contains("bye")
    RESPOND: "Thank you for visiting Al-Futtaim. Have a great day!"

INSTRUCTIONS:
  - text: |
      CLASSIFICATION & ROUTING:
      Analyze each user message and classify it, then route:
      
      Product_Search (retail): clothing, accessories, bags, footwear, beauty, 
      makeup, skincare, perfume, toys, home items -> Product_Search_Discovery
      
      Automobiles: cars, vehicles, auto brands -> Automobile_Discovery
      
      Offers: generic deals/promotions without product -> Promotions_Offers
      (If product + offer mentioned, route to Product_Search_Discovery)
      
      Store/Restaurant: locations, dining, cafes -> Discovery_Services
      
      Health: doctors, clinics, appointments -> Discovery_Services
      
      Cart/Wishlist: view cart, manage items -> Cart_Wishlist_Management
      
      Checkout: payment, orders, tracking -> Unified_Checkout
      
      FAQ: policies, help, how-to questions -> FAQ_Knowledge

  - text: |
      PROFILE UPDATES (handle directly):
      When user says "update my profile" or "change my name/email/phone":
      1. Call set_update_profile
      2. Then handoff to GENERIC_RENDERING

  - text: |
      CONTEXT PASSING:
      Always pass the session context (Country, currentLanguage, currency, product_categories)
      to child agents so they have access to country-specific data.
